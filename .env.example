# Supabase config (required for controller + signups data features)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Admin access allowlist (comma-separated); used as fallback allowlist
NEXT_PUBLIC_ADMIN_EMAILS=admin@example.com

# Optional notification bridge for marshal relay updates
NEXT_PUBLIC_DISCORD_PROXY_URL=

# Optional docs/status UI customization
NEXT_PUBLIC_DOCS_TITLE=Celestial Circuit Docs
NEXT_PUBLIC_DOCS_VERSION=v1
NEXT_PUBLIC_STATUS_PAGE_TITLE=Celestial Circuit Status

# Hosting path settings
# Leave unset for GitHub project-site deploys in Actions.
# Set empty for custom domain root deploys.
# NEXT_PUBLIC_BASE_PATH=
# Optional explicit asset prefix override.
# NEXT_PUBLIC_ASSET_PREFIX=
